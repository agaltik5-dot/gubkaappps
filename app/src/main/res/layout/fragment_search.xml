<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 1. ШАПКА: Логотип + Название ВУЗа -->
    <LinearLayout
        android:id="@+id/layout_app_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="16dp">

        <!-- Иконка/Логотип -->

        <!-- Текстовый блок шапки -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_university_logo"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="12dp"
            android:scaleType="centerCrop"
            android:src="@drawable/gubkin_logo"
            app:shapeAppearanceOverlay="@style/CircularImageView" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-bold"
                android:text="Расписание занятий"
                android:textColor="@color/ui_text_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="РГУ нефти и газа (НИУ) имени И.М. Губкина"
                android:textColor="@color/ui_text_sub"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 2. Вкладки (Факультеты / Преподаватели / Аудитории) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabIndicatorColor="@color/ui_primary"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/ui_primary"
        app:tabTextColor="@color/ui_text_sub">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Факультеты" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Преподаватели" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Аудитории" />
    </com.google.android.material.tabs.TabLayout>

    <!-- 3. Карточка с фильтрами (Семестр, Факультет, Группа) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/ui_surface"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Семестр -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Семестр"
                android:textColor="@color/ui_text_sub"
                android:textSize="11sp" />

            <Spinner
                android:id="@+id/spinner_semester"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:spinnerMode="dropdown" />

            <!-- Блок Факультет / Группа -->
            <LinearLayout
                android:id="@+id/layout_faculty_selectors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1.2"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Факультет"
                        android:textColor="@color/ui_text_sub"
                        android:textSize="11sp" />

                    <Spinner
                        android:id="@+id/spinner_faculty"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:spinnerMode="dropdown" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.8"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Группа"
                        android:textColor="@color/ui_text_sub"
                        android:textSize="11sp" />

                    <Spinner
                        android:id="@+id/spinner_group"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:spinnerMode="dropdown" />
                </LinearLayout>
            </LinearLayout>

            <!-- Текстовый поиск (по умолчанию скрыт) -->
            <EditText
                android:id="@+id/et_search_query"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_day_active"
                android:hint="Поиск..."
                android:paddingHorizontal="12dp"
                android:textColor="@color/ui_text_main"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 4. Список найденных пар / Заглушка "Расписание отсутствует" -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_search_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

</LinearLayout>